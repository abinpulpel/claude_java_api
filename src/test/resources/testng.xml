<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="ClaudeJavaApiSuite" parallel="methods" thread-count="4" verbose="1">

    <listeners>
        <listener class-name="com.claude.api.listeners.TestListener"/>
        <listener class-name="com.claude.api.listeners.AnnotationTransformer"/>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>

    <test name="PostsApiTests">
        <classes>
            <class name="com.claude.api.tests.PostsApiTest"/>
        </classes>
    </test>

    <test name="UsersApiTests">
        <classes>
            <class name="com.claude.api.tests.UsersApiTest"/>
        </classes>
    </test>

</suite>
